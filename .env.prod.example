# =========================================================
# 운영 환경 변수 템플릿 (T1-4)
#
# 사용:
#   cp .env.prod.example .env.prod
#   nano .env.prod
#   # 모든 [REQUIRED] 값을 채운 뒤 저장
#
# 보안:
#   - `.env.prod`는 `.gitignore` 처리됨 — 절대 커밋 X
#   - 운영에서는 `SPRING_PROFILES_ACTIVE=prod` (docker-compose.prod.yml에 자동 주입)로
#     ProductionSecretsValidator가 부팅 시 아래 [REQUIRED] 값을 검증.
#     디폴트 placeholder 그대로 두면 부팅 거부 → 안전.
#   - 시크릿 회전/관리 가이드: docs/deployment.md § 시크릿 관리
#
# 강한 비번 생성:
#   openssl rand -base64 24        # 32자 base64, 영문/숫자/기호 혼합
#   openssl rand -hex 16           # 32자 hex
# =========================================================

# --- [REQUIRED] MySQL ---
# 디폴트(coastpass 등) 그대로 두면 운영 프로파일에서 부팅 거부.
DB_ROOT_PASSWORD=__REPLACE_WITH_OPENSSL_RAND_24__
DB_USERNAME=__REPLACE_NON_DEFAULT__
DB_PASSWORD=__REPLACE_WITH_OPENSSL_RAND_24__

# --- [REQUIRED] 초기 admin 계정 ---
# 운영에서는 반드시 명시. 비워두면 ProductionSecretsValidator가 부팅 거부.
# (로컬 개발에서는 비워두면 SecureRandom 16자 + 로그 1회 노출이지만, 운영에서는
#  로그 유출이 곧 침해라 강제.)
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=__REPLACE_WITH_OPENSSL_RAND_24__

# --- Naver Shopping API ---
# 키 발급 받았으면 NAVER_MOCK_ENABLED=false + 두 키 모두 채우기.
# 안 받았으면 NAVER_MOCK_ENABLED=true 유지 (Mock 응답).
# mock-enabled=false인데 키가 비면 ProductionSecretsValidator가 부팅 거부.
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_MOCK_ENABLED=false

# --- 제휴 마케팅 (선택) ---
# 쿠팡 파트너스 가입 후 발급받은 ID (예: AF1234567). 비워두면 일반 검색 URL만 노출(수수료 X).
COUPANG_TRACKING_ID=
