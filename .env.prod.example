# =========================================================
# 운영 환경 변수 템플릿
# 사용: 이 파일을 .env.prod 로 복사 후 실제 값 채우기
#   cp .env.prod.example .env.prod
#   nano .env.prod
# .env.prod 는 git에 절대 커밋 X (.gitignore 처리됨)
# =========================================================

# --- MySQL (앱과 함께 docker-compose로 띄움) ---
DB_ROOT_PASSWORD=change-this-strong-root-password
DB_USERNAME=coast
DB_PASSWORD=change-this-strong-app-password

# --- 초기 admin 계정 ---
# 비워두면 부팅 시 SecureRandom으로 16자 랜덤 생성 + 로그에 1회 노출
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=

# --- Naver Shopping API ---
# 키 없으면 NAVER_MOCK_ENABLED=true로 둬도 동작 (Mock 응답)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_MOCK_ENABLED=true

# --- 제휴 마케팅 (선택) ---
# 쿠팡 파트너스 가입 후 발급받은 ID(예: AF1234567). 비워두면 일반 검색 URL만 노출(수수료 X).
COUPANG_TRACKING_ID=
